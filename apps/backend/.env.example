# OpenRouter API Key
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
TURNSTILE_SECRET_KEY=
# Optional expected frontend hostname for Turnstile verification (no protocol).
# Supports a single hostname only. An optional port suffix is accepted for
# validation convenience, but the port is not enforced because Cloudflare
# returns only the bare hostname from siteverify.
# Example: claudecope.com
TURNSTILE_EXPECTED_HOSTNAME=

# OpenRouter preferred providers (comma-separated list).
# When set, backend proxy requests include provider.order to prefer cheaper providers.
# This ONLY affects server-side requests using the backend's OPENROUTER_API_KEY.
# Does NOT affect BYOK (Bring Your Own Key) users - they control provider preferences via their own OpenRouter account.
# Leave empty to use OpenRouter's default routing.
OPENROUTER_PROVIDERS=DeepInfra,NovitaAI

# When "true", the OPENROUTER_PROVIDERS preference is applied to free-tier
# users only. Pro (Max) users bypass it and get OpenRouter's default routing.
# Defaults to "false" (preference applies to everyone).
OPENROUTER_PROVIDERS_FREE_ONLY=false

# Ticket refinement endpoint (POST /api/tickets/refine). Disabled by default
# because it is unauthenticated, has no rate limit, and writes into the
# shared community backlog visible to all users. Set to "true" to enable.
ENABLE_TICKET_REFINE=false

# Quota allowances (optional — defaults shown).
# FREE_QUOTA_LIMIT controls the per-session cap for free-tier users.
# PRO_INITIAL_QUOTA controls the initial per-license allowance granted when
# a Polar license key is synced via /api/account/sync.
FREE_QUOTA_LIMIT=20
PRO_INITIAL_QUOTA=100

# ─── Polar.sh (License Validation) ──────────────────
# Server-side access token used to validate Polar license keys when a user
# runs `/sync <COPE-XXX>`. Create one at https://polar.sh/settings →
# "Access Tokens". Without this the /api/account/sync endpoint returns 500.
POLAR_ACCESS_TOKEN=

# Your Polar organization ID. Required alongside POLAR_ACCESS_TOKEN for
# license key validation. Find it at https://polar.sh/settings → "Organization".
POLAR_ORGANIZATION_ID=

# Webhook secret for automatic license provisioning/revocation.
# Set this to the signing secret from your Polar webhook configuration.
# Without this the /webhooks/polar endpoint returns 500.
POLAR_WEBHOOK_SECRET=

# ─── PostHog (Rate-Limit Telemetry) ────────────────
# Server-side PostHog capture is used by the edge rate-limiter to emit
# Rate_Limit_Triggered events so operators can build dashboards and
# alerts outside of Cloudflare analytics.
# Create a project at https://posthog.com and grab the project API key
# from Settings → Project → "Project API Key".
POSTHOG_API_KEY=
# PostHog ingest host. Use https://app.posthog.com for PostHog Cloud,
# or your self-hosted instance URL (no trailing slash).
POSTHOG_HOST=https://app.posthog.com

# ─── IP Hash Pepper (GDPR Anonymization) ──────────
# Secret pepper used to HMAC-SHA256 IP addresses for rate-limit identity.
# REQUIRED when RATE_LIMIT_KV is bound. If missing while KV is configured,
# the worker returns 503 on BOTH /api/chat AND /api/verify (fail-closed)
# and logs an error. This affects all rate-limited endpoints, not just chat.
# Generate with: openssl rand -hex 32
IP_HASH_PEPPER=
