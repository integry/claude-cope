# ───────────────────────────────────────────────────────
# Claude Cope — Environment Configuration
# ───────────────────────────────────────────────────────
# Copy to .env.staging or .env.production and fill in values.
# Run scripts/setup.sh <env> to create Cloudflare resources.
# Run scripts/deploy.sh <env> to deploy.

# ─── Cloudflare Account ──────────────────────────────
CLOUDFLARE_ACCOUNT_ID=

# ─── Backend (Cloudflare Worker) ─────────────────────
CF_WORKER_NAME=claude-cope-api-staging
CF_D1_DATABASE_NAME=claude-cope-db-staging
CF_D1_DATABASE_ID=

# OpenRouter API key — set as a Worker secret, not a var
OPENROUTER_API_KEY=

# OpenRouter preferred providers (comma-separated list, e.g., "Together,Fireworks")
# When set, backend proxy requests include provider.order to prefer cheaper providers.
# This ONLY affects server-side requests using the backend's OPENROUTER_API_KEY.
# Does NOT affect BYOK (Bring Your Own Key) users - they control provider preferences via their own OpenRouter account.
# Leave empty to use OpenRouter's default routing.
OPENROUTER_PROVIDERS=

# Worker route (optional — leave empty to use default *.workers.dev URL).
# For production with a custom domain, set the route pattern and zone:
#   CF_WORKER_ROUTE=claudecope.com/api/*
#   CF_WORKER_ZONE=claudecope.com
CF_WORKER_ROUTE=
CF_WORKER_ZONE=

# ─── Frontend (Cloudflare Pages) ─────────────────────
CF_PAGES_PROJECT=claude-cope-staging

# Base URL for API calls from the frontend.
# Leave EMPTY when Worker and Pages share the same domain (e.g. production
# with a route like claudecope.com/api/*). Relative /api/* paths just work.
# Set to the full Worker URL when they're on different domains (staging):
#   VITE_API_BASE=https://claude-cope-api-staging.<you>.workers.dev
VITE_API_BASE=

# Supabase (real-time ticker)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PartyKit (multiplayer)
VITE_PARTYKIT_HOST=

# ─── PartyKit Server ─────────────────────────────────
PARTYKIT_PROJECT_NAME=claude-cope-party-staging

# ─── CORS (comma-separated origins the Worker accepts) ─
ALLOWED_ORIGINS=http://localhost:5173

# ─── Quota allowances ───────────────────────────────
# Per-session free-tier request allowance. Defaults to 20 when unset.
FREE_QUOTA_LIMIT=20
# Per-license Pro-tier initial request allowance. Defaults to 100 when unset.
PRO_INITIAL_QUOTA=100

# Frontend mirrors of the above — the HeaderBar quota display reads these so
# the rendered bar matches backend enforcement. Keep them in sync with the
# backend values above.
VITE_FREE_QUOTA_LIMIT=20
VITE_PRO_INITIAL_QUOTA=100

# ─── Polar.sh (License Sales & Checkout) ─────────────
# Server-side access token for validating Polar license keys via the
# /api/account/sync endpoint. Create one at https://polar.sh/settings
# → "Access Tokens". Required for Max license activation.
POLAR_ACCESS_TOKEN=

# Your Polar organization ID. Required alongside POLAR_ACCESS_TOKEN for
# license key validation. Find it at https://polar.sh/settings → "Organization".
POLAR_ORGANIZATION_ID=

# Checkout URLs for the upgrade overlay. Create products in your Polar
# dashboard (https://polar.sh) and paste the checkout links here.
# When empty the corresponding button shows a terminal-style error.
VITE_UPGRADE_CHECKOUT_SINGLE=
VITE_UPGRADE_CHECKOUT_MULTI=
# Display prices shown on the upgrade buttons. Defaults: $4.99 / $19.99
VITE_UPGRADE_PRICE_SINGLE=
VITE_UPGRADE_PRICE_MULTI=

# ─── BYOK (Bring Your Own Key) ───────────────────────
# Controls whether users can supply their own OpenRouter API key via `/key`.
# Defaults to enabled when unset. Set to `false` to hide the `/key` command,
# BYOK badges, and profile messaging, and to force all chat traffic through
# the backend proxy (`${VITE_API_BASE}/api/chat`) even if a stale `apiKey`
# exists in a user's saved session.
VITE_ENABLE_BYOK=true
